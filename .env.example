# Copy to .env for local `docker compose up` (Coolify auto-generates these on deploy).

# --- Postgres ---
POSTGRES_USER=looptilt
POSTGRES_DB=looptilt
POSTGRES_PORT=5432
POSTGRES_HOSTNAME=postgres
SERVICE_PASSWORD_POSTGRES=looptilt

# --- Redis ---
REDIS_HOSTNAME=redis
REDIS_PORT=6379

# --- Public URLs (Coolify sets SERVICE_URL_* from Domains tab; override manually if needed) ---
SERVICE_URL_FRONTEND=http://localhost:3000
SERVICE_URL_BACKEND=http://localhost:3001
# Optional manual overrides — these take priority over SERVICE_URL_* magic vars:
# FRONTEND_URL=https://app.yourdomain.com
# BACKEND_URL=https://api.yourdomain.com

# --- Coolify auto-generated secrets ---
SERVICE_PASSWORD_BETTERAUTH=your-secure-secret-key-min-32-characters-long
SERVICE_PASSWORD_ENCRYPTION=change-me-to-a-32-byte-min-secret-string!!

# --- Backend (set in Coolify Environment Variables tab) ---
API_PREFIX=api
# Required for production boot (Coolify Environment Variables tab):
# OPENAI_API_KEY=sk-...   OR keep ALLOW_HEURISTIC_FALLBACK=true for degraded AI
# UNOSEND_API_KEY=un_...  and SMTP_FROM=hello@yourdomain.com (when REQUIRE_EMAIL_VERIFICATION=true)
OPENAI_API_KEY=
ALLOW_HEURISTIC_FALLBACK=true
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
EMAIL_PROVIDER=unosend
UNOSEND_API_KEY=
UNOSEND_BASE_URL=https://api.unosend.co
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
REQUIRE_EMAIL_VERIFICATION=true
KIT_OAUTH_CLIENT_ID=
KIT_OAUTH_CLIENT_SECRET=
KIT_OAUTH_REDIRECT_URI=
KIT_WEBHOOK_SECRET=
