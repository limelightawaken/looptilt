# Copy to .env for local `docker compose up` (Coolify generates these on deploy).

# --- Postgres (SERVICE_PASSWORD_POSTGRES is auto-generated by Coolify) ---
POSTGRES_USER=looptilt
POSTGRES_DB=looptilt
SERVICE_PASSWORD_POSTGRES=looptilt

# --- Coolify service URLs (assign domains to frontend + backend in Coolify) ---
SERVICE_URL_FRONTEND=http://localhost:3000
SERVICE_URL_BACKEND=http://localhost:3001

# --- Auto-generated secrets (Coolify SERVICE_BASE64_* magic vars) ---
SERVICE_BASE64_BETTERAUTH=your-secure-secret-key-min-32-characters-long
SERVICE_BASE64_ENCRYPTION=change-me-to-a-32-byte-min-secret-string!!

# --- Backend (optional — set in Coolify Environment Variables tab) ---
API_PREFIX=api
OPENAI_API_KEY=
ALLOW_HEURISTIC_FALLBACK=false
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
REQUIRE_EMAIL_VERIFICATION=true
KIT_OAUTH_CLIENT_ID=
KIT_OAUTH_CLIENT_SECRET=
KIT_OAUTH_REDIRECT_URI=
KIT_WEBHOOK_SECRET=
