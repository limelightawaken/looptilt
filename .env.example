# Copy to .env for local `docker compose up` (Coolify auto-generates these on deploy).

# --- Postgres ---
POSTGRES_USER=looptilt
POSTGRES_DB=looptilt
POSTGRES_PORT=5432
POSTGRES_HOSTNAME=looptilt-postgres
SERVICE_PASSWORD_POSTGRES=looptilt

# --- Redis ---
REDIS_HOSTNAME=looptilt-redis
REDIS_PORT=6379

# --- Coolify FQDNs (assign domains to looptilt-frontend + looptilt-backend) ---
SERVICE_FQDN_LOOPTILTFRONTEND=http://localhost:3000
SERVICE_FQDN_LOOPTILTBACKEND=http://localhost:3001

# --- Coolify auto-generated secrets ---
SERVICE_PASSWORD_BETTERAUTH=your-secure-secret-key-min-32-characters-long
SERVICE_PASSWORD_ENCRYPTION=change-me-to-a-32-byte-min-secret-string!!

# --- Backend (set in Coolify Environment Variables tab) ---
API_PREFIX=api
OPENAI_API_KEY=
ALLOW_HEURISTIC_FALLBACK=false
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
REQUIRE_EMAIL_VERIFICATION=true
KIT_OAUTH_CLIENT_ID=
KIT_OAUTH_CLIENT_SECRET=
KIT_OAUTH_REDIRECT_URI=
KIT_WEBHOOK_SECRET=
