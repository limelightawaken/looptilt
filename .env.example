# Copy to .env for local `docker compose up`, or set these in Coolify Environment Variables.
# URL structure matches local docker — set BACKEND_URL / FRONTEND_URL explicitly.

# --- Postgres ---
POSTGRES_USER=looptilt
POSTGRES_DB=looptilt
POSTGRES_PORT=5432
POSTGRES_HOSTNAME=postgres
SERVICE_PASSWORD_POSTGRES=looptilt

# --- Redis ---
REDIS_HOSTNAME=redis
REDIS_PORT=6379

# --- Public URLs (required — same vars local docker and Coolify use) ---
BACKEND_URL=https://api-looptilt.tayosadique.com
FRONTEND_URL=https://looptilt.tayosadique.com
SERVICE_URL_BACKEND=https://api-looptilt.tayosadique.com
SERVICE_URL_FRONTEND=https://looptilt.tayosadique.com

# --- Coolify auto-generated secrets ---
SERVICE_PASSWORD_BETTERAUTH=your-secure-secret-key-min-32-characters-long
SERVICE_PASSWORD_ENCRYPTION=change-me-to-a-32-byte-min-secret-string!!

# --- Backend ---
API_PREFIX=api
OPENAI_API_KEY=
ALLOW_HEURISTIC_FALLBACK=true
AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
EMAIL_PROVIDER=unosend
UNOSEND_API_KEY=
UNOSEND_BASE_URL=https://api.unosend.co
SMTP_FROM=
REQUIRE_EMAIL_VERIFICATION=false
KIT_OAUTH_CLIENT_ID=
KIT_OAUTH_CLIENT_SECRET=
KIT_OAUTH_REDIRECT_URI=https://api-looptilt.tayosadique.com/api/esp/oauth/kit/callback
KIT_OAUTH_SCOPE=read write
KIT_WEBHOOK_SECRET=
