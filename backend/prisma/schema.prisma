generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String       @id @default(cuid())
  email         String       @unique
  name          String?
  emailVerified Boolean      @default(false)
  image         String?
  role          Role         @default(USER)
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  sessions      Session[]
  accounts      Account[]
  newsletters   Newsletter[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([identifier, value])
  @@map("verifications")
}

model Newsletter {
  id          String                  @id @default(cuid())
  userId      String
  name        String
  description String?
  espProvider EspProvider             @default(NONE)
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  archive     ArchiveIssue[]
  fingerprint NewsletterFingerprint?
  drafts      GhostwriterDraft[]
  esp         EspConnection?

  @@index([userId])
  @@map("newsletters")
}

enum EspProvider {
  NONE
  KIT
  BEEHIIV
  KLAVIYO
  MAILCHIMP
}

model ArchiveIssue {
  id           String     @id @default(cuid())
  newsletterId String
  title        String
  content      String     @db.Text
  publishedAt  DateTime?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)

  @@index([newsletterId])
  @@map("archive_issues")
}

enum FingerprintStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

model NewsletterFingerprint {
  id           String            @id @default(cuid())
  newsletterId String            @unique
  status       FingerprintStatus @default(PENDING)
  version      Int               @default(1)
  topics       Json?
  voice        Json?
  audience     Json?
  depthFormat  Json?
  obsessions   Json?
  summary      String?           @db.Text
  errorMessage String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  newsletter   Newsletter        @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  drafts       GhostwriterDraft[]

  @@map("newsletter_fingerprints")
}

enum DraftStatus {
  DRAFT
  REVIEW
  APPROVED
}

model GhostwriterDraft {
  id            String                 @id @default(cuid())
  newsletterId  String
  fingerprintId String?
  title         String
  outline       Json?
  content       String                 @db.Text
  status        DraftStatus            @default(DRAFT)
  createdAt     DateTime               @default(now())
  updatedAt     DateTime               @updatedAt
  newsletter    Newsletter             @relation(fields: [newsletterId], references: [id], onDelete: Cascade)
  fingerprint   NewsletterFingerprint? @relation(fields: [fingerprintId], references: [id], onDelete: SetNull)

  @@index([newsletterId])
  @@map("ghostwriter_drafts")
}

model EspConnection {
  id           String     @id @default(cuid())
  newsletterId String     @unique
  provider     EspProvider
  isActive     Boolean    @default(false)
  lastSyncedAt DateTime?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  newsletter   Newsletter @relation(fields: [newsletterId], references: [id], onDelete: Cascade)

  @@map("esp_connections")
}
