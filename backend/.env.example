DATABASE_URL="postgresql://[db-user]:[db-password]@localhost:5432/looptilt?schema=public"
BETTER_AUTH_SECRET="your-secure-secret-key-min-32-characters-long"
BETTER_AUTH_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

NODE_ENV=development
PORT=3001
API_PREFIX=api

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=your-bucket-name

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@example.com
# Email verification (set to 'true' to enable, defaults to true in production)
REQUIRE_EMAIL_VERIFICATION=false

# --- AI layer (OpenAI) ---
# Required in production unless ALLOW_HEURISTIC_FALLBACK=true is set.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Allow the deterministic heuristic provider to run in production (degraded AI).
ALLOW_HEURISTIC_FALLBACK=false

# --- ESP integration (Kit / ConvertKit) + signal simulator ---
KIT_API_BASE_URL=https://api.kit.com/v4
# Public URL of THIS backend (used for Kit webhook target registration).
APP_PUBLIC_URL=http://localhost:3001
# 32+ char secret used to encrypt stored ESP API keys at rest (AES-256-GCM).
ENCRYPTION_KEY=change-me-to-a-32-byte-min-secret-string
# Enables the local signal simulator. MUST be false in production.
ENABLE_SIMULATOR=true
