DATABASE_URL="postgresql://looptilt:looptilt@localhost:5432/looptilt?schema=public"

# --- Redis (BullMQ background jobs + scheduling) ---
REDIS_HOST=localhost
REDIS_PORT=6379
# Leave empty for a local Redis without auth.
REDIS_PASSWORD=

BETTER_AUTH_SECRET="your-secure-secret-key-min-32-characters-long"
BETTER_AUTH_URL="http://localhost:3001"
FRONTEND_URL="http://localhost:3000"

NODE_ENV=development
PORT=3001
API_PREFIX=api

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET=your-bucket-name

# Email — Resend-compatible API (Unosend, Resend, etc.) or SMTP fallback
# Use EMAIL_PROVIDER=resend for HTTP API providers; smtp for traditional SMTP.
EMAIL_PROVIDER=resend
# Resend-compatible API key (Unosend keys start with un_, Resend keys with re_).
RESEND_API_KEY=
# Optional API URL override. Defaults to https://api.resend.com/emails
# Unosend: https://api.unosend.co/v1/emails
RESEND_API_URL=https://api.unosend.co/v1/emails
# From address (must be verified in your email provider).
SMTP_FROM=noreply@example.com

# SMTP fallback (when EMAIL_PROVIDER=smtp) — optional in development; required in production
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-email@example.com
# SMTP_PASS=your-email-password
# Email verification: off in development by default; always on when NODE_ENV=production.
# Set to 'true' locally to test the verification flow (email provider must be configured).
REQUIRE_EMAIL_VERIFICATION=false

# --- AI layer (OpenAI-compatible) ---
# Required in production unless ALLOW_HEURISTIC_FALLBACK=true is set.
OPENAI_API_KEY=
# Optional base URL for OpenAI-compatible providers (DeepSeek, Ollama, etc.).
# Omit to use the default OpenAI endpoint.
# OPENAI_BASE_URL=https://api.deepseek.com
OPENAI_MODEL=gpt-4o-mini
# DeepSeek example:
# OPENAI_BASE_URL=https://api.deepseek.com
# OPENAI_MODEL=deepseek-chat
# Allow the deterministic heuristic provider to run in production (degraded AI).
ALLOW_HEURISTIC_FALLBACK=false

# --- ESP integration (Kit / ConvertKit) + signal simulator ---
KIT_API_BASE_URL=https://api.kit.com/v4
# Public URL of THIS backend (used for Kit webhook target registration).
APP_PUBLIC_URL=http://localhost:3001
# 32+ char secret used to encrypt stored ESP API keys at rest (AES-256-GCM).
ENCRYPTION_KEY=change-me-to-a-32-byte-min-secret-string
# Enables the local signal simulator. MUST be false in production.
ENABLE_SIMULATOR=true
# Shared secret appended to Kit webhook URLs to authenticate inbound calls.
# When set, inbound webhooks missing/mismatching this secret are rejected.
KIT_WEBHOOK_SECRET=
